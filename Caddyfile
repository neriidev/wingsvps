# Evita redirecionar HTTP→HTTPS durante o challenge ACME; senão o pedido
# https://FQDN/.well-known/... vai para o Wings e devolve 401.
{
	auto_https disable_redirects
}

{$WINGS_FQDN} {
	tls {
		issuer acme {
			disable_tlsalpn_challenge
		}
	}
	@notAcme not path /.well-known/acme-challenge/*
	reverse_proxy @notAcme 127.0.0.1:8080
}
